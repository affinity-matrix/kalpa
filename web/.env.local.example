# Inference server (set after running start-inference.sh)
INFERENCE_SERVER_URL=http://x.x.x.x:8080
INFERENCE_API_KEY=your-shared-secret

# GCP — for generating signed video playback URLs
GCP_PROJECT_ID=your-project-id
# Paste the full service account JSON as a single-line string
GCP_SA_KEY={"type":"service_account","project_id":"..."}
GCS_BUCKET=kalpa-assets

# X402 — payment configuration
# See lib/x402.ts for where these are used
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_PAYTO_ADDRESS=0x...         # your Aptos wallet address (receives payments)
X402_NETWORK=aptos:testnet
