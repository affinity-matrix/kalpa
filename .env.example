# Lambda Labs
LAMBDA_API_KEY=your-lambda-api-key
LAMBDA_SSH_KEY_NAME=your-ssh-key-name   # SSH key registered in Lambda console
LAMBDA_REGION=us-east-1                 # Check Lambda console for H100 NVL availability

# GCS (used for model weights, artifacts, and scripts)
GCS_BUCKET=gs://kalpa-assets
# Service account JSON, base64-encoded — used to auth gcloud on Lambda instances:
# GCP_SA_KEY_B64=$(base64 -i path/to/sa-key.json | tr -d '\n')
GCP_SA_KEY_B64=

# HuggingFace
# Required for Gemma text encoder (gated model — accept terms at hf.co/google/gemma-3-12b-it-qat-q4_0-unquantized first)
HF_TOKEN=hf_...

# Shelby / Aptos Wallet (testnet)
# Network: testnet
# Wallet needs: APT (gas) + ShelbyUSD (storage payments)
# Fund APT at: https://aptos.dev/en/network/faucet
SHELBY_NETWORK=testnet
SHELBY_WALLET_PRIVKEY=0x...
SHELBY_WALLET_ADDRESS=0x...

# RunPod (alternative to Lambda when Lambda is out of capacity)
# Pre-requisite: add SSH public key in RunPod console → Settings → SSH Keys
# GPU type IDs vary — query available types, see header comment in train-runpod.sh
RUNPOD_API_KEY=your-runpod-api-key
TRAIN_GPU_TYPE=NVIDIA H100 NVL   # override if needed based on availability

# Inference server
# INFERENCE_SERVER_URL is set after running start-inference.sh — it prints the instance IP
INFERENCE_SERVER_URL=http://x.x.x.x:8080
INFERENCE_API_KEY=generate-a-random-secret-here
